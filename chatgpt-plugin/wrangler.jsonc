{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mcp-web-validator-chatgpt",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-12",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "ratelimits": [
    {
      "name": "MCP_RATE_LIMITER",
      "namespace_id": "2026071001",
      "simple": {
        "limit": 300,
        "period": 60
      }
    },
    {
      "name": "SITE_AUDIT_RATE_LIMITER",
      "namespace_id": "2026071201",
      "simple": {
        "limit": 10,
        "period": 60
      }
    }
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.05
    }
  },
  "routes": [
    {
      "pattern": "web-validator-mcp.digestseo.com",
      "custom_domain": true
    }
  ],
  "workers_dev": false
}
