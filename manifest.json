{
  "manifest_version": "0.2",
  "name": "mcp-web-validator",
  "display_name": "Web Validator by DigestSEO",
  "version": "1.0.1",
  "description": "Validate HTML/CSS, audit SEO and JSON-LD, check links, and capture responsive screenshots.",
  "author": {
    "name": "AKzar1el",
    "url": "https://github.com/AKzar1el"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AKzar1el/mcp-web-validator"
  },
  "homepage": "https://digestseo.com/validator-mcp/",
  "license": "MIT",
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/dist/index.js"
      ]
    }
  },
  "tools": [
    {
      "name": "html_validate_local",
      "title": "Validate local HTML",
      "description": "Reads a bounded local HTML file and sends its markup to the W3C Nu HTML Checker. Use only files the user is authorized to share.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "filePath": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "description": "Absolute or workspace-relative path to an HTML file."
          }
        },
        "required": [
          "filePath"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "lastLine": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "lastColumn": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "firstLine": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "firstColumn": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "extract": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "errors"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "html_validate_url",
      "title": "Validate a public URL",
      "description": "Fetches a bounded public HTTP(S) page, then sends its markup to the W3C Nu HTML Checker. Private, reserved, credentialed, and nonstandard-port destinations are rejected.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Public HTTP(S) URL on port 80 or 443."
          }
        },
        "required": [
          "url"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "lastLine": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "lastColumn": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "firstLine": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "firstColumn": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "extract": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "fetchedUrl": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "errors"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "css_validate_local",
      "title": "Validate local CSS",
      "description": "Reads a bounded local CSS file and sends it to the W3C Jigsaw CSS Validator. Use only files the user is authorized to share.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "filePath": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "description": "Absolute or workspace-relative path to a CSS file."
          }
        },
        "required": [
          "filePath"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "type": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "context": {
                  "type": "string"
                }
              },
              "required": [
                "line",
                "type",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "errors"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "seo_audit_metadata",
      "title": "Audit SEO metadata",
      "description": "Analyzes supplied HTML locally for metadata, heading structure, viewport configuration, image alternatives, and Open Graph fields.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "htmlContent": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000000,
            "description": "Raw HTML markup to inspect locally."
          }
        },
        "required": [
          "htmlContent"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "info"
                  ]
                },
                "category": {
                  "type": "string",
                  "enum": [
                    "SEO",
                    "Schema",
                    "BrokenLinks",
                    "Accessibility"
                  ]
                },
                "message": {
                  "type": "string"
                },
                "element": {
                  "type": "string"
                }
              },
              "required": [
                "severity",
                "category",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "totalIssues": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "truncated": {
            "type": "boolean"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "issues",
          "totalIssues",
          "truncated"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "links_check_broken",
      "title": "Check public links",
      "description": "Resolves and checks up to 25 public HTTP(S) links in supplied HTML. Redirects are reported but not followed, and response bodies are discarded.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "htmlContent": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000000,
            "description": "Raw HTML markup containing links to check."
          },
          "baseUrl": {
            "description": "Optional public HTTP(S) base URL used to resolve relative links.",
            "type": "string",
            "format": "uri"
          },
          "maxLinks": {
            "default": 25,
            "type": "integer",
            "minimum": 1,
            "maximum": 25
          }
        },
        "required": [
          "htmlContent"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string"
                },
                "status": {
                  "anyOf": [
                    {
                      "type": "integer",
                      "minimum": -9007199254740991,
                      "maximum": 9007199254740991
                    },
                    {
                      "type": "string",
                      "enum": [
                        "blocked",
                        "failed"
                      ]
                    }
                  ]
                },
                "ok": {
                  "type": "boolean"
                },
                "message": {
                  "type": "string"
                }
              },
              "required": [
                "url",
                "status",
                "ok"
              ],
              "additionalProperties": false
            }
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "links"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "schema_validate_markup",
      "title": "Validate JSON-LD syntax",
      "description": "Parses JSON-LD blocks in supplied HTML locally and reports empty blocks or JSON syntax errors. It does not validate vocabulary semantics.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "htmlContent": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000000,
            "description": "Raw HTML containing JSON-LD script blocks."
          }
        },
        "required": [
          "htmlContent"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "info"
                  ]
                },
                "category": {
                  "type": "string",
                  "enum": [
                    "SEO",
                    "Schema",
                    "BrokenLinks",
                    "Accessibility"
                  ]
                },
                "message": {
                  "type": "string"
                },
                "element": {
                  "type": "string"
                }
              },
              "required": [
                "severity",
                "category",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "totalIssues": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "truncated": {
            "type": "boolean"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "issues",
          "totalIssues",
          "truncated"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "report_generate_validation",
      "title": "Generate a validation report",
      "description": "Combines W3C HTML/CSS validation, local SEO/accessibility checks, JSON-LD syntax checks, and a bounded public-link check into a Markdown and structured report.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "htmlFilePath": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "description": "Absolute or workspace-relative HTML file path."
          },
          "cssFilePath": {
            "description": "Optional absolute or workspace-relative CSS file path.",
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "baseUrl": {
            "description": "Optional public HTTP(S) base URL used to resolve relative links.",
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "htmlFilePath"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "report": {
            "type": "string"
          },
          "summary": {
            "type": "object",
            "properties": {
              "overallScore": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "htmlScore": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "cssScore": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "seoScore": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "linkScore": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "htmlErrors": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "htmlWarnings": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "cssErrors": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "seoErrors": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "seoWarnings": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "schemaErrors": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "linksChecked": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "brokenLinks": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "overallScore",
              "htmlScore",
              "cssScore",
              "seoScore",
              "linkScore",
              "htmlErrors",
              "htmlWarnings",
              "cssErrors",
              "seoErrors",
              "seoWarnings",
              "schemaErrors",
              "linksChecked",
              "brokenLinks"
            ],
            "additionalProperties": false
          },
          "htmlMessages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "lastLine": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "lastColumn": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "firstLine": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "firstColumn": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "extract": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "cssMessages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "type": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "context": {
                  "type": "string"
                }
              },
              "required": [
                "line",
                "type",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "seoIssues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "info"
                  ]
                },
                "category": {
                  "type": "string",
                  "enum": [
                    "SEO",
                    "Schema",
                    "BrokenLinks",
                    "Accessibility"
                  ]
                },
                "message": {
                  "type": "string"
                },
                "element": {
                  "type": "string"
                }
              },
              "required": [
                "severity",
                "category",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "schemaIssues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "info"
                  ]
                },
                "category": {
                  "type": "string",
                  "enum": [
                    "SEO",
                    "Schema",
                    "BrokenLinks",
                    "Accessibility"
                  ]
                },
                "message": {
                  "type": "string"
                },
                "element": {
                  "type": "string"
                }
              },
              "required": [
                "severity",
                "category",
                "message"
              ],
              "additionalProperties": false
            }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string"
                },
                "status": {
                  "anyOf": [
                    {
                      "type": "integer",
                      "minimum": -9007199254740991,
                      "maximum": 9007199254740991
                    },
                    {
                      "type": "string",
                      "enum": [
                        "blocked",
                        "failed"
                      ]
                    }
                  ]
                },
                "ok": {
                  "type": "boolean"
                },
                "message": {
                  "type": "string"
                }
              },
              "required": [
                "url",
                "status",
                "ok"
              ],
              "additionalProperties": false
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "report",
          "summary",
          "htmlMessages",
          "cssMessages",
          "seoIssues",
          "schemaIssues",
          "links"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
    {
      "name": "screenshot_capture",
      "title": "Capture responsive screenshots",
      "description": "Renders a local HTML file or HTTP(S) URL in a sandboxed local Chromium browser and writes PNG screenshots to the requested directory. Existing matching files may be replaced.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "targetPath": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "description": "Local HTML path or HTTP(S) URL to render."
          },
          "outputDir": {
            "default": ".mcp-validator/screenshots",
            "description": "Directory where PNG screenshots will be written.",
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "viewports": {
            "minItems": 1,
            "maxItems": 8,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9_-]{1,50}$"
                },
                "width": {
                  "type": "integer",
                  "minimum": 200,
                  "maximum": 3840
                },
                "height": {
                  "type": "integer",
                  "minimum": 200,
                  "maximum": 4320
                }
              },
              "required": [
                "name",
                "width",
                "height"
              ]
            }
          }
        },
        "required": [
          "targetPath"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "screenshots": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "viewportName": {
                  "type": "string"
                },
                "width": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "height": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "outputPath": {
                  "type": "string"
                }
              },
              "required": [
                "viewportName",
                "width",
                "height",
                "outputPath"
              ],
              "additionalProperties": false
            }
          },
          "outputDirectory": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "screenshots",
          "outputDirectory"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    }
  ],
  "icon": "icon.jpg"
}
