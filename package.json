{
  "name": "mcp-web-validator",
  "version": "1.1.0",
  "description": "W3C HTML/CSS Validator and Technical SEO Audit MCP Server for AI coding assistants.",
  "main": "dist/index.js",
  "bin": {
    "mcp-web-validator": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AKzar1el/mcp-web-validator.git"
  },
  "homepage": "https://digestseo.com/validator-mcp/",
  "bugs": {
    "url": "https://github.com/AKzar1el/mcp-web-validator/issues"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && node --test test/*.test.js",
    "sync:manifests": "node scripts/sync-manifests.mjs",
    "check:manifests": "node scripts/sync-manifests.mjs --check",
    "check": "npm test && npm run check:manifests",
    "prepublishOnly": "npm run check"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "w3c",
    "validator",
    "html-validator",
    "seo",
    "seo-audit",
    "accessibility"
  ],
  "author": "AKzar1el",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "mcpName": "io.github.AKzar1el/mcp-web-validator",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.0.0",
    "puppeteer": "^25.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
